{
    "name": "misaf/laravel-sms-gateway-melipayamak",
    "description": "Melipayamak SMS gateway driver for Laravel.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "laravel-package",
        "sms",
        "sms-api",
        "sms-gateway",
        "sms-provider",
        "sms-driver",
        "melipayamak",
        "melipayamak-sms"
    ],
    "homepage": "https://github.com/misaf/laravel-sms-gateway-melipayamak",
    "support": {
        "issues": "https://github.com/misaf/laravel-sms-gateway-melipayamak/issues",
        "source": "https://github.com/misaf/laravel-sms-gateway-melipayamak"
    },
    "authors": [
        {
            "name": "Ehsan Mahmoodi",
            "email": "misaf.1990@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "misaf/laravel-sms-gateway": "^1.0",
        "spatie/laravel-package-tools": "^1.92"
    },
    "require-dev": {
        "guzzlehttp/guzzle": "^7.10",
        "larastan/larastan": "^3.9.2",
        "laravel/pint": "^1.29",
        "mockery/mockery": "^1.6.12",
        "nunomaduro/collision": "^8.8.3",
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^4.3.2",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "scripts": {
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest"
    },
    "autoload": {
        "psr-4": {
            "Misaf\\LaravelSmsGatewayMelipayamak\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Misaf\\LaravelSmsGatewayMelipayamak\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Misaf\\LaravelSmsGatewayMelipayamak\\MelipayamakSmsGatewayServiceProvider"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
